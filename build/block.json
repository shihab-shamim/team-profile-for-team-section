{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "tsb/team-profile-pro",
  "version": "1.0.0",
  "title": "Team Profile",
  "category": "widgets",
  "description": "Team Profile is a WordPress plugin that allows you to create team profiles on your website.",
  "keywords": [
    "Team Profile",
    "team",
    "profile"
  ],
  "textdomain": "info-cards",
  "attributes": {
    "align": {
      "type": "string",
      "default": "wide"
    },
    "alignment": {
      "type": "string",
      "default": "center"
    },
    "purposeType": {
      "type": "string",
      "default": "test"
    },
    "colors": {
      "type": "object",
      "default": {
        "color": "black",
        "bg": "#B1C5A4"
      }
    }
  },
  "supports": {
    "align": [
      "wide",
      "full"
    ],
    "html": false
  },
  "example": {
    "attributes": {}
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./view.css",
  "render": "file:./render.php",
  "viewScript": "file:./view.js"
}